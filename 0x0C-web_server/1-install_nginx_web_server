#!/usr/bin/env bash
# a script that installs and sets up nginx

# Update package list
apt-get update

# Allow incoming traffic for Nginx HTTP
ufw allow 'Nginx HTTP'

# Install Nginx
apt-get install -y nginx

# Create a simple HTML page with "Hello World!"
echo "Hello World!" > /var/www/html/index.html

# Start nginx
sudo service nginx start
